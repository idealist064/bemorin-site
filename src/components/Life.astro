---
---

<section class="section life-section" id="life">
  <div class="container">
    <div class="section__header">
      <p class="section__label mono accent">→ Life</p>
      <h2 class="section__title">
        Reclaim your life.<br><em>On your own terms.</em>
      </h2>
      <p class="section__sub">
        Time, discipline, language, meaning — the four levers that change everything.
      </p>
    </div>

    <div class="life-grid">
      <!-- Big Ass Calendar -->
      <div class="life-card" id="calendar">
        <div class="life-card__num mono">01</div>
        <div class="life-card__icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="32" height="28" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <path d="M4 16h32" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 4v8M28 4v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="10" y="22" width="5" height="5" rx="0.5" fill="currentColor" opacity="0.6"/>
            <rect x="18" y="22" width="5" height="5" rx="0.5" fill="currentColor" opacity="0.3"/>
            <rect x="26" y="22" width="5" height="5" rx="0.5" fill="currentColor" opacity="0.8"/>
          </svg>
        </div>
        <h3 class="life-card__title">Big Ass Calendar</h3>
        <p class="life-card__desc">
          The exact time management system I use to run 5 projects and 1,500km 
          of training simultaneously. Visual, brutal, effective.
        </p>
        <div class="life-card__tags">
          <span>Time</span><span>Planning</span><span>Focus</span>
        </div>
        <a href="#newsletter" class="life-card__cta">Get it free →</a>
      </div>

      <!-- 30-Day Resilience -->
      <div class="life-card" id="resilience">
        <div class="life-card__num mono">02</div>
        <div class="life-card__icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="1.5"/>
            <path d="M20 8v4M20 28v4M8 20h4M28 20h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="20" cy="20" r="5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="life-card__title">30-Day Resilience Challenges</h3>
        <p class="life-card__desc">
          Cold starts. Deep work sprints. Stoic practice. One protocol a day 
          for 30 days — until discipline becomes identity.
        </p>
        <div class="life-card__tags">
          <span>Discipline</span><span>Stoicism</span><span>Habits</span>
        </div>
        <a href="#newsletter" class="life-card__cta">Join challenge →</a>
      </div>

      <!-- Kikiyomi -->
      <div class="life-card" id="kikiyomi">
        <div class="life-card__num mono">03</div>
        <div class="life-card__icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 12h16M8 18h12M8 24h14M8 30h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="30" cy="24" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M28 24l1.5 1.5 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="life-card__title">The Kikiyomi Method</h3>
        <p class="life-card__desc">
          Learn any language through native immersion. Audio + Text, no grammar 
          drills. The method I used to become fluent — fast.
        </p>
        <div class="life-card__tags">
          <span>Language</span><span>Immersion</span><span>Method</span>
        </div>
        <a href="#newsletter" class="life-card__cta">Learn more →</a>
      </div>

      <!-- Books / Logotherapy -->
      <div class="life-card life-card--featured" id="books">
        <div class="life-card__num mono">04</div>
        <div class="life-card__icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 6h20a1 1 0 0 1 1 1v26a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M14 14h12M14 20h12M14 26h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="life-card__title">Logotherapy & Active Nihilism</h3>
        <p class="life-card__desc">
          My books and scripts on finding meaning in chaos. Rock bottom isn't the 
          end — it's the launchpad. A framework for turning adversity into direction.
        </p>
        <div class="life-card__tags">
          <span>Meaning</span><span>Philosophy</span><span>Resilience</span>
        </div>
        <a href="#newsletter" class="life-card__cta life-card__cta--featured">Read the books →</a>
      </div>
    </div>
  </div>
</section>

<style>
.section {
  padding: var(--section-pad) 0;
  border-top: 1px solid var(--gray-800);
}

.section__header {
  max-width: 680px;
  margin-bottom: 60px;
}

.section__label {
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.section__title {
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 5vw, 5rem);
  line-height: 0.92;
  letter-spacing: -0.01em;
  margin-bottom: 20px;
}

.section__title em {
  font-family: var(--font-serif);
  font-style: italic;
  color: var(--accent);
}

.section__sub {
  font-size: 0.95rem;
  color: var(--gray-400);
  line-height: 1.6;
}

.life-section {
  background: var(--gray-900);
}

.life-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
}

.life-card {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 40px;
  background: var(--black);
  border: 1px solid var(--gray-800);
  transition: border-color 0.2s;
}

.life-card:hover {
  border-color: var(--gray-600);
}

.life-card--featured {
  border-color: rgba(200, 255, 0, 0.2);
}

.life-card--featured:hover {
  border-color: rgba(200, 255, 0, 0.5);
}

.life-card__num {
  font-size: 0.65rem;
  color: var(--gray-600);
  letter-spacing: 0.1em;
}

.life-card__icon {
  width: 40px;
  height: 40px;
  color: var(--accent);
}

.life-card__title {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--white);
  line-height: 1.2;
}

.life-card__desc {
  font-size: 0.875rem;
  color: var(--gray-300);
  line-height: 1.7;
  flex: 1;
}

.life-card__tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.life-card__tags span {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 8px;
  border: 1px solid var(--gray-700);
  color: var(--gray-500);
}

.life-card__cta {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  border-bottom: 1px solid rgba(200, 255, 0, 0.4);
  padding-bottom: 2px;
  transition: border-color 0.2s;
  width: fit-content;
}

.life-card__cta:hover {
  border-color: var(--accent);
}

.life-card__cta--featured {
  background: var(--accent);
  color: var(--black);
  padding: 10px 20px;
  border: none;
  margin-top: 4px;
}

.life-card__cta--featured:hover {
  background: var(--white);
}

@media (max-width: 768px) {
  .life-grid { grid-template-columns: 1fr; }
}
</style>
